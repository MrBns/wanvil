{
  "name": "wanvil",
  "version": "0.1.1-beta",
  "private": false,
  "type": "module",
  "files": [
    "README.md",
    "cli/dist/**/*.js",
    "server/dist/**/*.js",
    "shared/dist/**/*.js",
    "client/dist/**/*",
    "prisma/schema.prisma",
    "shared/generated/prisma/**/*"
  ],
  "bin": {
    "wanvil": "./cli/dist/index.js"
  },
  "scripts": {
    "dev": "vite --config client/vite.config.ts",
    "dev:server": "tsx watch server/src/index.ts",
    "dev:cli": "tsx cli/src/index.ts",
    "dev:full": "concurrently -n client,cli -c cyan,magenta \"npm run dev\" \"npm run dev:cli\"",
    "build": "npx prisma generate && tsc --build && tsc --noEmit -p client/tsconfig.json && vite build --config client/vite.config.ts",
    "preview": "vite preview --config client/vite.config.ts",
    "start:cli": "node cli/dist/index.js",
    "lint": "biome check .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.0",
    "@prisma/adapter-better-sqlite3": "^7.7.0",
    "@prisma/config": "^7.7.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.554.0",
    "pino": "^10.1.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.9.0",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "tailwind-merge": "^3.5.0",
    "viem": "^2.47.10",
    "zod": "^4.1.12",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@prisma/client": "^7.7.0",
    "prisma": "^7.7.0",
    "@tailwindcss/vite": "^4.1.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.1.0",
    "concurrently": "^9.2.1",
    "pino-pretty": "^13.1.2",
    "tailwindcss": "^4.1.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.0",
    "vite": "^8.0.0"
  }
}